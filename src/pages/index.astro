---
import Layout from "../layouts/Layout.astro";
import { siteConfig } from "../lib/config";

const skills = ["TypeScript", "PostgreSQL", "Flutter"];
const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Nikolas Padilla",
  jobTitle: "Software Engineer",
  url: siteConfig.url,
  image: `${siteConfig.url}/headshot.webp`,
});
---

<Layout>
  <script slot="head" is:inline type="application/ld+json" set:html={jsonLd} />

  <div class="animate-page-in mx-auto grid max-w-3xl items-start gap-12 px-6 py-24 md:grid-cols-[280px,1fr]">
    <aside class="animate-fade-up flex gap-6">
      <img
        src="/headshot.webp"
        alt="Nikolas Padilla"
        class="motion-avatar h-24 w-24 shrink-0 rounded-full object-cover transition-transform duration-300"
        width="96"
        height="96"
        fetchpriority="high"
      />
      <div>
        <h1 class="text-gradient-motion mb-1 text-2xl font-bold tracking-tight">Nikolas Padilla</h1>
        <p class="mb-4 text-text-secondary">Software Engineer</p>

        <div class="mb-4 flex flex-wrap gap-2">
          {
            skills.map((skill, index) => (
              <span
                class="animate-fade-up rounded border border-border px-2 py-0.5 text-xs text-text-secondary"
                style={`--motion-delay: ${120 + index * 70}ms`}
              >
                {skill}
              </span>
            ))
          }
        </div>

        <div class="flex flex-wrap gap-2">
          <a
            href="/projects"
            class="motion-link rounded border border-accent px-3 py-1.5 text-xs font-medium text-accent hover:bg-accent/10 hover:no-underline hover:shadow-sm"
          >
            View Projects
          </a>
          <a
            href="/resume.pdf"
            target="_blank"
            class="motion-link rounded border border-accent px-3 py-1.5 text-xs font-medium text-accent hover:bg-accent/10 hover:no-underline hover:shadow-sm"
          >
            Download Resume
          </a>
        </div>
      </div>
    </aside>

    <div class="animate-fade-up" style="--motion-delay: 120ms">
      <p class="mb-6 leading-relaxed text-text-primary">
        Currently leading software development at AnyBackFlow.com, a backflow services company in Arizona. Building the
        ReportFlow platform, a unified system connecting field technicians and office operations. Rewriting the existing
        mobile app into a full platform with shared database architecture.
      </p>
      <p>
        <a href="/projects/sample-project" class="motion-link inline-block text-accent hover:underline">
          Curious? Read more...
        </a>
      </p>
    </div>
  </div>
</Layout>
