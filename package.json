		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^24.12.2",
		"mdsvex": "^0.12.7",
		"svelte": "^5.55.1",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.58.0",
		"vite": "^7.3.1",
		"vite-plugin-devtools-json": "^1.0.0"
	}
